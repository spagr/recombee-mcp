# Recombee MCP Server Configuration
# Copy this file to .env and fill in your values.

# Required: Your Recombee database ID
RECOMBEE_DB_ID=your-database-id

# Required: Your Recombee private API token
RECOMBEE_PRIVATE_TOKEN=your-private-token

# Region: eu-west (default), us-west, ap-se, ca-east
RECOMBEE_REGION=eu-west

# Profile: production (default, read-only) or sandbox (allows write tools)
RECOMBEE_PROFILE=production

# Enable write tools (only effective in sandbox profile)
RECOMBEE_WRITE_ENABLED=false

# Log level: DEBUG, INFO (default), WARNING, ERROR
RECOMBEE_LOG_LEVEL=INFO

# Optional: Custom audit log directory (default: platform-specific app data dir)
# RECOMBEE_AUDIT_LOG_DIR=

# Optional: Integration test credentials (for tests/integration/)
# RECOMBEE_INTEGRATION_DB_ID=
# RECOMBEE_INTEGRATION_TOKEN=
